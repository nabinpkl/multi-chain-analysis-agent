{
  "$defs": {
    "ClaimKind": {
      "description": "Closed enum: the renderer dispatches to per-kind cards. New variants require a deliberate change. v0 only emits `Profile`; the rest exist so ships 3/5/7 fill them without later refactor.",
      "enum": [
        "profile",
        "pattern",
        "comparison",
        "summary",
        "pulse"
      ],
      "title": "ClaimKind",
      "type": "string"
    },
    "EdgeSummary": {
      "properties": {
        "dst": {
          "title": "Dst",
          "type": "string"
        },
        "src": {
          "title": "Src",
          "type": "string"
        },
        "volume": {
          "title": "Volume",
          "type": "number"
        }
      },
      "required": [
        "dst",
        "src",
        "volume"
      ],
      "title": "EdgeSummary",
      "type": "object"
    },
    "Kind": {
      "enum": [
        "wallet"
      ],
      "title": "Kind",
      "type": "string"
    },
    "Kind11": {
      "enum": [
        "edge"
      ],
      "title": "Kind11",
      "type": "string"
    },
    "Kind12": {
      "enum": [
        "community"
      ],
      "title": "Kind12",
      "type": "string"
    },
    "Kind13": {
      "enum": [
        "time-range"
      ],
      "title": "Kind13",
      "type": "string"
    },
    "Kind14": {
      "enum": [
        "number"
      ],
      "title": "Kind14",
      "type": "string"
    },
    "NodeSummary": {
      "properties": {
        "addr": {
          "title": "Addr",
          "type": "string"
        },
        "role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Role"
        }
      },
      "required": [
        "addr"
      ],
      "title": "NodeSummary",
      "type": "object"
    },
    "NumberRef": {
      "properties": {
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "metric",
        "value"
      ],
      "title": "NumberRef",
      "type": "object"
    },
    "PolicyVerdictApproved": {
      "additionalProperties": false,
      "properties": {
        "verdict": {
          "const": "approved",
          "default": "approved",
          "title": "Verdict",
          "type": "string"
        }
      },
      "title": "PolicyVerdictApproved",
      "type": "object"
    },
    "PolicyVerdictRetracted": {
      "additionalProperties": false,
      "properties": {
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "verdict": {
          "const": "retracted",
          "default": "retracted",
          "title": "Verdict",
          "type": "string"
        }
      },
      "required": [
        "reason"
      ],
      "title": "PolicyVerdictRetracted",
      "type": "object"
    },
    "ProvenanceRef": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProvenanceRef11"
        },
        {
          "$ref": "#/$defs/ProvenanceRef12"
        },
        {
          "$ref": "#/$defs/ProvenanceRef13"
        },
        {
          "$ref": "#/$defs/ProvenanceRef14"
        },
        {
          "$ref": "#/$defs/ProvenanceRef15"
        }
      ],
      "description": "Tagged reference back to a graph entity. The frontend's render-surface derivation picks live highlight, modal, or inline chip based on the ref shape (see plan: \"Frontend render-surface derivation rule\").",
      "title": "ProvenanceRef"
    },
    "ProvenanceRef11": {
      "description": "`idx` is None when the wallet is not in the current live window (route to subgraph modal instead of live-graph chip).",
      "properties": {
        "addr": {
          "title": "Addr",
          "type": "string"
        },
        "idx": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Idx"
        },
        "kind": {
          "$ref": "#/$defs/Kind"
        }
      },
      "required": [
        "addr",
        "kind"
      ],
      "title": "ProvenanceRef11",
      "type": "object"
    },
    "ProvenanceRef12": {
      "description": "Stable id format: `\"<edge_idx>:<gen>\"`.",
      "properties": {
        "dst": {
          "minimum": 0,
          "title": "Dst",
          "type": "integer"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/Kind11"
        },
        "src": {
          "minimum": 0,
          "title": "Src",
          "type": "integer"
        }
      },
      "required": [
        "dst",
        "id",
        "kind",
        "src"
      ],
      "title": "ProvenanceRef12",
      "type": "object"
    },
    "ProvenanceRef13": {
      "description": "Tagged reference back to a graph entity. The frontend's render-surface derivation picks live highlight, modal, or inline chip based on the ref shape (see plan: \"Frontend render-surface derivation rule\").",
      "properties": {
        "id": {
          "minimum": 0,
          "title": "Id",
          "type": "integer"
        },
        "kind": {
          "$ref": "#/$defs/Kind12"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "ProvenanceRef13",
      "type": "object"
    },
    "ProvenanceRef14": {
      "description": "Populated by ship-5 warehouse primitives.",
      "properties": {
        "from_s": {
          "minimum": 0,
          "title": "From S",
          "type": "integer"
        },
        "kind": {
          "$ref": "#/$defs/Kind13"
        },
        "to_s": {
          "minimum": 0,
          "title": "To S",
          "type": "integer"
        }
      },
      "required": [
        "from_s",
        "kind",
        "to_s"
      ],
      "title": "ProvenanceRef14",
      "type": "object"
    },
    "ProvenanceRef15": {
      "description": "Aggregate metric reference. `support` lists EdgeIds backing the number so the user can drill in.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/Kind14"
        },
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "support": {
          "items": {
            "type": "string"
          },
          "title": "Support",
          "type": "array"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "kind",
        "metric",
        "support",
        "value"
      ],
      "title": "ProvenanceRef15",
      "type": "object"
    },
    "StubMarker": {
      "additionalProperties": false,
      "description": "Per-claim badge: which stubs short-circuited during this claim's\nemission. Persists into history so stub provenance survives even\nafter the global registry is cleared.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "promoted_in_ship": {
          "maximum": 255,
          "minimum": 0,
          "title": "Promoted In Ship",
          "type": "integer"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "name",
        "reason",
        "promoted_in_ship"
      ],
      "title": "StubMarker",
      "type": "object"
    },
    "SubgraphSlice": {
      "description": "Self-contained subgraph rendered on its own canvas in a modal. Used by ship-5 for historical results that don't share layout state with the live graph.",
      "properties": {
        "edges": {
          "items": {
            "$ref": "#/$defs/EdgeSummary"
          },
          "title": "Edges",
          "type": "array"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/NodeSummary"
          },
          "title": "Nodes",
          "type": "array"
        },
        "time_range": {
          "anyOf": [
            {
              "$ref": "#/$defs/TimeRangeWire"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "edges",
        "nodes"
      ],
      "title": "SubgraphSlice",
      "type": "object"
    },
    "TimeRangeWire": {
      "properties": {
        "from_s": {
          "minimum": 0,
          "title": "From S",
          "type": "integer"
        },
        "to_s": {
          "minimum": 0,
          "title": "To S",
          "type": "integer"
        }
      },
      "required": [
        "from_s",
        "to_s"
      ],
      "title": "TimeRangeWire",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Streamed analytical statement. The body uses `${ref:N}`\nplaceholders the frontend replaces with interactive chips at\nrender time. `provenance[N]` is the typed entry the chip\nresolves against.\n\nWire shape locked to match Rust `agent::types::Claim` byte-for-byte.\nDrift surfaces as failed Phase I.5 SSE golden parse tests.",
  "properties": {
    "body_markdown": {
      "description": "Structured paragraph; ${ref:N} placeholders -> provenance chips.",
      "title": "Body Markdown",
      "type": "string"
    },
    "emitted_at_ms": {
      "description": "Wallclock ms since session started. u32 in Rust.",
      "minimum": 0,
      "title": "Emitted At Ms",
      "type": "integer"
    },
    "headline": {
      "description": "One-line plaintext headline.",
      "title": "Headline",
      "type": "string"
    },
    "id": {
      "description": "ULID, sortable by emission order.",
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/ClaimKind"
    },
    "policy_verdict": {
      "discriminator": {
        "mapping": {
          "approved": "#/$defs/PolicyVerdictApproved",
          "retracted": "#/$defs/PolicyVerdictRetracted"
        },
        "propertyName": "verdict"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/PolicyVerdictApproved"
        },
        {
          "$ref": "#/$defs/PolicyVerdictRetracted"
        }
      ],
      "title": "Policy Verdict"
    },
    "provenance": {
      "items": {
        "$ref": "#/$defs/ProvenanceRef"
      },
      "title": "Provenance",
      "type": "array"
    },
    "session_id": {
      "title": "Session Id",
      "type": "string"
    },
    "stubs_active": {
      "items": {
        "$ref": "#/$defs/StubMarker"
      },
      "title": "Stubs Active",
      "type": "array"
    },
    "subgraph_slice": {
      "anyOf": [
        {
          "$ref": "#/$defs/SubgraphSlice"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "support_numbers": {
      "items": {
        "$ref": "#/$defs/NumberRef"
      },
      "title": "Support Numbers",
      "type": "array"
    }
  },
  "required": [
    "id",
    "session_id",
    "kind",
    "headline",
    "body_markdown",
    "provenance",
    "support_numbers",
    "policy_verdict",
    "stubs_active",
    "emitted_at_ms"
  ],
  "title": "Claim",
  "type": "object"
}
