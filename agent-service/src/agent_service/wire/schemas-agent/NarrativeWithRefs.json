{
  "$defs": {
    "Kind": {
      "enum": [
        "wallet"
      ],
      "title": "Kind",
      "type": "string"
    },
    "Kind11": {
      "enum": [
        "edge"
      ],
      "title": "Kind11",
      "type": "string"
    },
    "Kind12": {
      "enum": [
        "community"
      ],
      "title": "Kind12",
      "type": "string"
    },
    "Kind13": {
      "enum": [
        "time-range"
      ],
      "title": "Kind13",
      "type": "string"
    },
    "Kind14": {
      "enum": [
        "number"
      ],
      "title": "Kind14",
      "type": "string"
    },
    "ProvenanceRef": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProvenanceRef11"
        },
        {
          "$ref": "#/$defs/ProvenanceRef12"
        },
        {
          "$ref": "#/$defs/ProvenanceRef13"
        },
        {
          "$ref": "#/$defs/ProvenanceRef14"
        },
        {
          "$ref": "#/$defs/ProvenanceRef15"
        }
      ],
      "description": "Tagged reference back to a graph entity. The frontend's render-surface derivation picks live highlight, modal, or inline chip based on the ref shape (see plan: \"Frontend render-surface derivation rule\").",
      "title": "ProvenanceRef"
    },
    "ProvenanceRef11": {
      "description": "`idx` is None when the wallet is not in the current live window (route to subgraph modal instead of live-graph chip).",
      "properties": {
        "addr": {
          "title": "Addr",
          "type": "string"
        },
        "idx": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Idx"
        },
        "kind": {
          "$ref": "#/$defs/Kind"
        }
      },
      "required": [
        "addr",
        "kind"
      ],
      "title": "ProvenanceRef11",
      "type": "object"
    },
    "ProvenanceRef12": {
      "description": "Stable id format: `\"<edge_idx>:<gen>\"`.",
      "properties": {
        "dst": {
          "minimum": 0,
          "title": "Dst",
          "type": "integer"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/Kind11"
        },
        "src": {
          "minimum": 0,
          "title": "Src",
          "type": "integer"
        }
      },
      "required": [
        "dst",
        "id",
        "kind",
        "src"
      ],
      "title": "ProvenanceRef12",
      "type": "object"
    },
    "ProvenanceRef13": {
      "description": "Tagged reference back to a graph entity. The frontend's render-surface derivation picks live highlight, modal, or inline chip based on the ref shape (see plan: \"Frontend render-surface derivation rule\").",
      "properties": {
        "id": {
          "minimum": 0,
          "title": "Id",
          "type": "integer"
        },
        "kind": {
          "$ref": "#/$defs/Kind12"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "ProvenanceRef13",
      "type": "object"
    },
    "ProvenanceRef14": {
      "description": "Populated by ship-5 warehouse primitives.",
      "properties": {
        "from_s": {
          "minimum": 0,
          "title": "From S",
          "type": "integer"
        },
        "kind": {
          "$ref": "#/$defs/Kind13"
        },
        "to_s": {
          "minimum": 0,
          "title": "To S",
          "type": "integer"
        }
      },
      "required": [
        "from_s",
        "kind",
        "to_s"
      ],
      "title": "ProvenanceRef14",
      "type": "object"
    },
    "ProvenanceRef15": {
      "description": "Aggregate metric reference. `support` lists EdgeIds backing the number so the user can drill in.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/Kind14"
        },
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "support": {
          "items": {
            "type": "string"
          },
          "title": "Support",
          "type": "array"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "kind",
        "metric",
        "support",
        "value"
      ],
      "title": "ProvenanceRef15",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Approved free-form prose. May contain inline `${ref:N}` tokens\nthe renderer resolves against `provenance` (assembled by the loop\nfrom this turn's emitted Claims, concatenated provenance arrays\nin emission order).",
  "properties": {
    "provenance": {
      "items": {
        "$ref": "#/$defs/ProvenanceRef"
      },
      "title": "Provenance",
      "type": "array"
    },
    "text": {
      "title": "Text",
      "type": "string"
    }
  },
  "required": [
    "text",
    "provenance"
  ],
  "title": "NarrativeWithRefs",
  "type": "object"
}
