{
  "$defs": {
    "FieldChangeCountChanged": {
      "additionalProperties": false,
      "description": "Count-class field where any delta is meaningful.",
      "properties": {
        "current": {
          "title": "Current",
          "type": "number"
        },
        "kind": {
          "const": "count_changed",
          "default": "count_changed",
          "title": "Kind",
          "type": "string"
        },
        "prior": {
          "title": "Prior",
          "type": "number"
        }
      },
      "required": [
        "prior",
        "current"
      ],
      "title": "FieldChangeCountChanged",
      "type": "object"
    },
    "FieldChangeNumberMoved": {
      "additionalProperties": false,
      "description": "Numeric field outside per-class tolerance. `pct` is the signed\npercent change; 0.0 when prior is 0.",
      "properties": {
        "current": {
          "title": "Current",
          "type": "number"
        },
        "kind": {
          "const": "number_moved",
          "default": "number_moved",
          "title": "Kind",
          "type": "string"
        },
        "pct": {
          "title": "Pct",
          "type": "number"
        },
        "prior": {
          "title": "Prior",
          "type": "number"
        }
      },
      "required": [
        "prior",
        "current",
        "pct"
      ],
      "title": "FieldChangeNumberMoved",
      "type": "object"
    },
    "FieldChangeSetChanged": {
      "additionalProperties": false,
      "description": "Entity-list field where membership changed. `added`/`removed`\ncarry the keys (typically wallet addresses).",
      "properties": {
        "added": {
          "items": {
            "type": "string"
          },
          "title": "Added",
          "type": "array"
        },
        "kind": {
          "const": "set_changed",
          "default": "set_changed",
          "title": "Kind",
          "type": "string"
        },
        "removed": {
          "items": {
            "type": "string"
          },
          "title": "Removed",
          "type": "array"
        }
      },
      "required": [
        "added",
        "removed"
      ],
      "title": "FieldChangeSetChanged",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "One field's change between prior turn's primitive output and the\nfreshly re-fetched output. `field_path` is dotted (e.g.\n`stats.in_volume_lamports`). `primitive` is the producing primitive\nname (e.g. `wallet_profile`).",
  "properties": {
    "change": {
      "discriminator": {
        "mapping": {
          "count_changed": "#/$defs/FieldChangeCountChanged",
          "number_moved": "#/$defs/FieldChangeNumberMoved",
          "set_changed": "#/$defs/FieldChangeSetChanged"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/FieldChangeNumberMoved"
        },
        {
          "$ref": "#/$defs/FieldChangeSetChanged"
        },
        {
          "$ref": "#/$defs/FieldChangeCountChanged"
        }
      ],
      "title": "Change"
    },
    "field_path": {
      "title": "Field Path",
      "type": "string"
    },
    "primitive": {
      "title": "Primitive",
      "type": "string"
    }
  },
  "required": [
    "field_path",
    "primitive",
    "change"
  ],
  "title": "FieldDelta",
  "type": "object"
}
