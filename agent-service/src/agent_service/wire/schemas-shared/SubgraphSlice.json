{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubgraphSlice",
  "description": "Self-contained subgraph rendered on its own canvas in a modal. Used by ship-5 for historical results that don't share layout state with the live graph.",
  "type": "object",
  "required": [
    "edges",
    "nodes"
  ],
  "properties": {
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EdgeSummary"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/NodeSummary"
      }
    },
    "time_range": {
      "anyOf": [
        {
          "$ref": "#/definitions/TimeRangeWire"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "EdgeSummary": {
      "type": "object",
      "required": [
        "dst",
        "src",
        "volume"
      ],
      "properties": {
        "dst": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "volume": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "NodeSummary": {
      "type": "object",
      "required": [
        "addr"
      ],
      "properties": {
        "addr": {
          "type": "string"
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TimeRangeWire": {
      "type": "object",
      "required": [
        "from_s",
        "to_s"
      ],
      "properties": {
        "from_s": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "to_s": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
