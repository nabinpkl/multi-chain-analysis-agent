{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PrimitiveResponseEnvelope",
  "description": "Generic primitive response envelope. Mirrors `PrimitiveOutput<T>` from the existing primitive trait but flattened for the wire so Python doesn't need to learn about the Rust generic.\n\n`value` is intentionally `serde_json::Value` here in the Rust shape so this single envelope can wrap any primitive's output. The Python client typed-validates `value` against the matching per-primitive output model.",
  "type": "object",
  "required": [
    "provenance",
    "value"
  ],
  "properties": {
    "provenance": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProvenanceRef"
      }
    },
    "subgraph_slice": {
      "anyOf": [
        {
          "$ref": "#/definitions/SubgraphSlice"
        },
        {
          "type": "null"
        }
      ]
    },
    "value": true
  },
  "definitions": {
    "EdgeSummary": {
      "type": "object",
      "required": [
        "dst",
        "src",
        "volume"
      ],
      "properties": {
        "dst": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "volume": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "NodeSummary": {
      "type": "object",
      "required": [
        "addr"
      ],
      "properties": {
        "addr": {
          "type": "string"
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ProvenanceRef": {
      "description": "Tagged reference back to a graph entity. The frontend's render-surface derivation picks live highlight, modal, or inline chip based on the ref shape (see plan: \"Frontend render-surface derivation rule\").",
      "oneOf": [
        {
          "description": "`idx` is None when the wallet is not in the current live window (route to subgraph modal instead of live-graph chip).",
          "type": "object",
          "required": [
            "addr",
            "kind"
          ],
          "properties": {
            "addr": {
              "type": "string"
            },
            "idx": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint32",
              "minimum": 0.0
            },
            "kind": {
              "type": "string",
              "enum": [
                "wallet"
              ]
            }
          }
        },
        {
          "description": "Stable id format: `\"<edge_idx>:<gen>\"`.",
          "type": "object",
          "required": [
            "dst",
            "id",
            "kind",
            "src"
          ],
          "properties": {
            "dst": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "id": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "edge"
              ]
            },
            "src": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        },
        {
          "type": "object",
          "required": [
            "id",
            "kind"
          ],
          "properties": {
            "id": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "kind": {
              "type": "string",
              "enum": [
                "community"
              ]
            }
          }
        },
        {
          "description": "Populated by ship-5 warehouse primitives.",
          "type": "object",
          "required": [
            "from_s",
            "kind",
            "to_s"
          ],
          "properties": {
            "from_s": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "kind": {
              "type": "string",
              "enum": [
                "time-range"
              ]
            },
            "to_s": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        },
        {
          "description": "Aggregate metric reference. `support` lists EdgeIds backing the number so the user can drill in.",
          "type": "object",
          "required": [
            "kind",
            "metric",
            "support",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "number"
              ]
            },
            "metric": {
              "type": "string"
            },
            "support": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "value": {
              "type": "number",
              "format": "double"
            }
          }
        }
      ]
    },
    "SubgraphSlice": {
      "description": "Self-contained subgraph rendered on its own canvas in a modal. Used by ship-5 for historical results that don't share layout state with the live graph.",
      "type": "object",
      "required": [
        "edges",
        "nodes"
      ],
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EdgeSummary"
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NodeSummary"
          }
        },
        "time_range": {
          "anyOf": [
            {
              "$ref": "#/definitions/TimeRangeWire"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "TimeRangeWire": {
      "type": "object",
      "required": [
        "from_s",
        "to_s"
      ],
      "properties": {
        "from_s": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "to_s": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
