{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EmitClaimInput",
  "description": "Input shape the model sends. Matches `Claim` minus the runtime- stamped fields (`id`, `session_id`, `emitted_at_ms`, `policy_verdict`, `stubs_active`, which are runtime-controlled).",
  "type": "object",
  "required": [
    "body_markdown",
    "headline",
    "kind",
    "provenance"
  ],
  "properties": {
    "body_markdown": {
      "type": "string"
    },
    "headline": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/ClaimKind"
    },
    "provenance": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProvenanceRef"
      }
    },
    "subgraph_slice": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/SubgraphSlice"
        },
        {
          "type": "null"
        }
      ]
    },
    "support_numbers": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/NumberRef"
      }
    }
  },
  "definitions": {
    "ClaimKind": {
      "description": "Closed enum: the renderer dispatches to per-kind cards. New variants require a deliberate change. v0 only emits `Profile`; the rest exist so ships 3/5/7 fill them without later refactor.",
      "type": "string",
      "enum": [
        "profile",
        "pattern",
        "comparison",
        "summary",
        "pulse"
      ]
    },
    "EdgeSummary": {
      "type": "object",
      "required": [
        "dst",
        "src",
        "volume"
      ],
      "properties": {
        "dst": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "volume": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "NodeSummary": {
      "type": "object",
      "required": [
        "addr"
      ],
      "properties": {
        "addr": {
          "type": "string"
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "NumberRef": {
      "type": "object",
      "required": [
        "metric",
        "value"
      ],
      "properties": {
        "metric": {
          "type": "string"
        },
        "value": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "ProvenanceRef": {
      "description": "Tagged reference back to a graph entity. The frontend's render-surface derivation picks live highlight, modal, or inline chip based on the ref shape (see plan: \"Frontend render-surface derivation rule\").",
      "oneOf": [
        {
          "description": "`idx` is None when the wallet is not in the current live window (route to subgraph modal instead of live-graph chip).",
          "type": "object",
          "required": [
            "addr",
            "kind"
          ],
          "properties": {
            "addr": {
              "type": "string"
            },
            "idx": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint32",
              "minimum": 0.0
            },
            "kind": {
              "type": "string",
              "enum": [
                "wallet"
              ]
            }
          }
        },
        {
          "description": "Stable id format: `\"<edge_idx>:<gen>\"`.",
          "type": "object",
          "required": [
            "dst",
            "id",
            "kind",
            "src"
          ],
          "properties": {
            "dst": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "id": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "edge"
              ]
            },
            "src": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        },
        {
          "type": "object",
          "required": [
            "id",
            "kind"
          ],
          "properties": {
            "id": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "kind": {
              "type": "string",
              "enum": [
                "community"
              ]
            }
          }
        },
        {
          "description": "Populated by ship-5 warehouse primitives.",
          "type": "object",
          "required": [
            "from_s",
            "kind",
            "to_s"
          ],
          "properties": {
            "from_s": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "kind": {
              "type": "string",
              "enum": [
                "time-range"
              ]
            },
            "to_s": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        },
        {
          "description": "Aggregate metric reference. `support` lists EdgeIds backing the number so the user can drill in.",
          "type": "object",
          "required": [
            "kind",
            "metric",
            "support",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "number"
              ]
            },
            "metric": {
              "type": "string"
            },
            "support": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "value": {
              "type": "number",
              "format": "double"
            }
          }
        }
      ]
    },
    "SubgraphSlice": {
      "description": "Self-contained subgraph rendered on its own canvas in a modal. Used by ship-5 for historical results that don't share layout state with the live graph.",
      "type": "object",
      "required": [
        "edges",
        "nodes"
      ],
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EdgeSummary"
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NodeSummary"
          }
        },
        "time_range": {
          "anyOf": [
            {
              "$ref": "#/definitions/TimeRangeWire"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "TimeRangeWire": {
      "type": "object",
      "required": [
        "from_s",
        "to_s"
      ],
      "properties": {
        "from_s": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "to_s": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
