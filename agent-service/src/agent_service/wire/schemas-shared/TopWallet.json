{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TopWallet",
  "type": "object",
  "required": [
    "addr",
    "degree",
    "volume"
  ],
  "properties": {
    "addr": {
      "type": "string"
    },
    "degree": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "volume": {
      "type": "number",
      "format": "double"
    }
  }
}
