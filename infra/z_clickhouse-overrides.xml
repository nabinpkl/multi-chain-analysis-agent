<clickhouse>
    <!--
        Disable noisy internal observability tables. Default ClickHouse
        writes once-per-second snapshots to metric_log /
        asynchronous_metric_log, plus rows to query_log / text_log /
        trace_log / part_log on every internal event. On a busy dev box
        these tiny inserts dominate ReplacingMergeTree compaction work
        (measured: ~35M rows merged per 60s in asynchronous_metric_log
        alone vs ~26k in our actual edges table). Disabling them keeps
        CPU available for the real workload. Re-enable individually if
        you ever need to debug ClickHouse itself.

        text_log stays enabled at warning level so genuine problems
        still land somewhere queryable; the bulk INFO-level chatter is
        what we actually wanted gone. Container stderr is unaffected
        and remains the primary operational log surface.
    -->
    <metric_log remove="remove"/>
    <asynchronous_metric_log remove="remove"/>
    <trace_log remove="remove"/>
    <query_log remove="remove"/>
    <query_thread_log remove="remove"/>
    <query_views_log remove="remove"/>
    <query_metric_log remove="remove"/>
    <part_log remove="remove"/>
    <processors_profile_log remove="remove"/>
    <opentelemetry_span_log remove="remove"/>
    <asynchronous_insert_log remove="remove"/>
    <backup_log remove="remove"/>
    <crash_log remove="remove"/>
    <error_log remove="remove"/>
    <latency_log remove="remove"/>
    <s3queue_log remove="remove"/>
    <session_log remove="remove"/>
    <text_log>
        <level>warning</level>
    </text_log>
</clickhouse>
