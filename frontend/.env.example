# URL where the Rust data plane is reachable from the browser.
# Serves graph, analytics, and diagnostics endpoints.
# Local dev:  http://localhost:8002
# Deployed:   https://api.chain.nabin.org (or wherever the Cloudflare Tunnel points)
NEXT_PUBLIC_API_URL=http://localhost:8002

# URL where the Python agent service is reachable from the browser.
# Serves /agent/ask + /agent/stream/{id} (proto canonical JSON SSE).
# Local dev:  http://localhost:8003
# Deployed:   https://agent.chain.nabin.org (or matching tunnel route)
NEXT_PUBLIC_AGENT_URL=http://localhost:8003
