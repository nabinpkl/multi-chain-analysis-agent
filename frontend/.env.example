# URL where the Rust data plane is reachable from the browser.
# Serves graph, analytics, and diagnostics endpoints.
# Local dev:  http://localhost:8002
# Deployed:   whatever hostname your ingress puts in front of the
#             api service's :PORT listener (default 8002).
NEXT_PUBLIC_API_URL=http://localhost:8002

# URL where the Python agent service is reachable from the browser.
# Serves /agent/ask + /agent/stream/{id} (proto canonical JSON SSE).
# Local dev:  http://localhost:8003
# Deployed:   whatever hostname your ingress puts in front of the
#             agent-service container's :8003 listener.
NEXT_PUBLIC_AGENT_URL=http://localhost:8003

# Public hostname this frontend is served from. When set, becomes the
# <link rel="canonical"> target and the og:url meta. Leave unset for
# local dev and for any deploy that does not need a canonical URL;
# omitting both metas is preferable to shipping a wrong one.
# Example: https://chain.example.org
NEXT_PUBLIC_CANONICAL_URL=

# Footer attribution. Both must be set to render the "Built by <name>"
# link in the site footer; both unset (the OSS default) means the
# block does not render, so a fork does not ship the upstream author's
# attribution. If the URL hostname is linkedin.com the LinkedIn icon
# is used; anything else gets the generic external-link icon.
# Example: NEXT_PUBLIC_BUILT_BY_NAME="Jane Doe"
#          NEXT_PUBLIC_BUILT_BY_URL="https://linkedin.com/in/jane-doe"
NEXT_PUBLIC_BUILT_BY_NAME=
NEXT_PUBLIC_BUILT_BY_URL=
