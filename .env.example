
# ─── Server ───────────────────────────────────────────────────────────
PORT=8002
# Internal HTTP listener inside the api container. Carries /turn/* and
# /primitive/* (the snapshot-lease + primitive surface the Python agent
# at :8003 calls). NOT host-published in docker-compose and NOT in the
# cloudflared tunnel ingress, so external callers cannot reach it; the
# agent-service container talks to it via the docker compose network as
# http://api:8004. Public surface (/health, /graph/*) lives on PORT.
INTERNAL_PORT=8004
CORS_ORIGIN=<http://localhost:3000>  # frontend origin for CORS headers
RUST_LOG=info,tower_http=debug
# LOG_FORMAT=json   # uncomment for prod (JSON lines for log shippers)

# ─── ClickHouse ───────────────────────────────────────────────────────
# Inside docker-compose these are overridden by the api service env block.
# These values are for running the server outside docker (cargo run).
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=multichain
CLICKHOUSE_USER=default
# Generate with: openssl rand -base64 24 | tr -d '/+=' | head -c 32
CLICKHOUSE_PASSWORD=

# ─── Solana RPC ───────────────────────────────────────────────────────
# Public mainnet caps per IP: 100 req/10s global, 40 req/10s per RPC method,
# 40 concurrent conns, 100 MB/30s. The RpcClient carries two independent
# rate-limit lanes so heavy /primitive/get_token_info traffic does not
# starve the ingester's getBlock cadence.
#
# Defaults: ingester at 1 req/s (matches mainnet's ~2.5 slot/s production
# rate as closely as the public RPC budget allows); primitive at 1 req/2s
# so agent narration cannot dominate. Combined ~1.5 req/s, comfortably
# under the per-IP cap with headroom for bursts. Drop to 400ms on
# ingester to keep pace with tip but expect more 429s.
SOLANA_RPC_URL=https://api.mainnet.solana.com
RPC_INGESTER_MIN_INTERVAL_MS=1000
RPC_PRIMITIVE_MIN_INTERVAL_MS=2000
INGEST_BATCH_SIZE=10000
INGEST_FLUSH_SECS=5

# TTL for the lazy ClickHouse-backed metadata cache backing
# /primitive/get_token_info, in slots. A row whose `fetched_at_slot`
# is more than this many slots behind the chain tip is treated as
# stale; the next read re-fetches via getAccountInfo and writes
# through. Default 9000 (~1 hour at Solana mainnet's 400 ms slot
# cadence). Becomes dead code once issue #48 (CDC instruction
# decoding for Metaplex + Token-2022 metadata mutations) lands; the
# materialized cache is kept fresh by ingest-time writes from then
# on, no read-side TTL refresh needed.
METADATA_CACHE_TTL_SLOTS=9000

# Comma-separated Host-header allowlist for the rmcp-backed `/mcp`
# route on the internal listener. Backstops the underlying network
# boundary against DNS-rebind attacks if this surface ever moves to
# a browser-reachable listener. Default covers loopback callers plus
# the docker compose service name `api`. Entries without a port
# match any port; entries with a port match only that port.
# Override examples:
#   MCP_ALLOWED_HOSTS=localhost,127.0.0.1,::1,api,k8s-svc
#   MCP_ALLOWED_HOSTS=mcp.example.com:8004
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,::1,api

# ─── Cloudflare Tunnel ────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Agent ────────────────────────────────────────────────────────────
# `AGENT_DEFAULT_PROVIDER` controls what `_normalize_provider("")`
# returns for empty / missing per-request overrides. Three values
# accepted: "openrouter", "gemini", "local". Codex is the active
# primary runtime today and authenticates via `~/.codex/auth.json`
# (ChatGPT subscription, no per-request billing). The pydantic-ai
# helpers (constitution gate, eval judge) do NOT have access to
# that subscription auth path; they go through `_resolve_provider`
# in `agent_service/llm.py`. Keeping them on Gemini's free
# OpenAI-compat endpoint means no real-money calls on those
# helpers. Switching this to "openrouter" + setting model ids to
# `openai/gpt-5.4-mini` is family-coherent with codex but requires
# OpenRouter spend; switching to "local" with a running LM Studio
# at `LOCAL_LLM_BASE_URL` is the all-local option.
#
# Model ids are env-driven so production and the eval substrate
# share one source of truth. `agent_service/evals/schema.py`
# derives the eval-judge forbidden-family list from these vars at
# YAML load time (preference-leakage prevention, ICLR 2026); swap
# a model here, the validator picks it up on the next process
# start. EVAL_JUDGE_MODEL is the default judge for `llm_judge`
# probes; case YAML can override per-probe via the `model:` field.
AGENT_DEFAULT_PROVIDER=gemini
AGENT_PRIMARY_MODEL=gemini-3.1-flash-lite
AGENT_POLICY_MODEL=gemini-3.1-flash-lite
EVAL_JUDGE_MODEL=gemini-3.1-flash-lite

# Disables the eval-judge family-leakage guard at schema-validation
# time. Default off (any non-true value): the guard rejects any
# judge model whose family prefix matches the agent's stage models
# (ICLR 2026: same-family judge biases toward agreeing with itself).
# Set to "true" / "1" / "yes" only when you intentionally want to
# run with a shared family, e.g. local dev iterating on rubric
# wording or experiments where the leakage is documented.
EVAL_ALLOW_SHARED_FAMILY=false

# Default runtime for AgentRequests that arrive with
# runtime=AGENT_RUNTIME_UNSPECIFIED. "codex" (default) | "pydantic_ai".
# Codex is the primary runtime; pydantic-ai is opt-in for comparison
# work. Cases that need a specific runtime regardless of operator
# config pin `inputs.runtime: AGENT_RUNTIME_*` in the YAML.
AGENT_DEFAULT_RUNTIME=codex

# Hard per-turn cap on data-lookup primitive dispatches
# (wallet_profile, community_summary, get_token_info). Reporting
# tools (emit_claim) do not count. When the cap is reached the
# next dispatch returns a no_more_lookups_this_turn tool result
# instead of executing; the model finalizes its narrative over
# the data it has, and the existing constitution + binding gates
# judge the result. Both runtimes read this value: pydantic-ai
# via agent_service.policy.resource_bounds, the Rust backend via
# AppState::new(). Keep both runtimes pointed at the same value
# or the parity breaks.
AGENT_TURN_TOOL_CALL_BUDGET=8

# Codex runtime model + reasoning effort. Mirrors AGENT_PRIMARY_MODEL
# / AGENT_POLICY_MODEL on the pydantic-ai side: env-driven so the
# operator dials cost / quality without code change. Empty / unset
# falls through to codex-cli's own default (today gpt-5.5; varies
# across cli versions). Accepted reasoning_effort values: low |
# medium | high (codex CLI semantics).
CODEX_PRIMARY_MODEL=
CODEX_REASONING_EFFORT=
# OpenRouter API key. Still required when AGENT_DEFAULT_PROVIDER is
# left at gemini, because the builder view's "openrouter" segment
# remains a one-click escape hatch for testing other free-tier
# models against a known-good Gemma baseline.
AGENT_API_KEY=
# Google Generative Language API key. Used by both /agent/gemini/models
# (the builder view's Gemini/Gemma dropdown source) and the runtime
# make_model gateway when AGENT_DEFAULT_PROVIDER=gemini or any
# request pins a role to the gemini provider.
GEMINI_API_KEY=

# Dev-only: the OpenAI-compatible base URL of a local model server
# (LM Studio, Ollama, vLLM, etc.) that the per-role override path in
# agent_service.llm.make_model and the GET /agent/local/models proxy
# route both consult when the frontend builder view's Models section
# pins a role to "local". Default `http://host.docker.internal:1234/v1`
# is LM Studio's default port + Docker Desktop's host alias. The
# agent-service docker-compose block carries `extra_hosts:
# ["host.docker.internal:host-gateway"]` so the alias resolves on
# Linux too.
#
# The chosen local model MUST support OpenAI-style tool calls AND
# JSON-schema structured output for the agent loop to function;
# small / older models that pass OpenAI protocol but ignore
# tool_choice will produce empty primary turns. Tool-capable picks:
# Qwen2.5-7B-Instruct, Llama-3.1-8B-Instruct, recent Mistrals.
LOCAL_LLM_BASE_URL=http://host.docker.internal:1234/v1

# ─── Langfuse self-hosted (Ship 1 step C, ADR 13) ─────────────────────
# Self-hosted Langfuse v3 stack, fed by the otel-collector via OTLP HTTP.
# UI lands at http://localhost:3000 after first boot. The
# LANGFUSE_INIT_* envvars below auto-create org + project + user +
# API keypair on first startup; deleting `data/langfuse-postgres`
# and starting again re-bootstraps from these values. See ADR 13 for
# why we accept the v3 architecture's storage footprint
# (postgres + redis + minio + dedicated clickhouse).
#
# Generate every secret below before any non-local use. One-shot
# script (zsh):
#   for k in NEXTAUTH_SECRET SALT LANGFUSE_CLICKHOUSE_PASSWORD \
#            LANGFUSE_POSTGRES_PASSWORD LANGFUSE_REDIS_AUTH \
#            LANGFUSE_MINIO_ROOT_PASSWORD LANGFUSE_INIT_USER_PASSWORD; do
#     echo "$k=$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)"
#   done
#   echo "ENCRYPTION_KEY=$(openssl rand -hex 32)"
#   echo "LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-$(openssl rand -hex 16)"
#   echo "LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-$(openssl rand -hex 32)"
# Then build the OTel auth header:
#   printf '%s:%s' "$PK" "$SK" | base64 -> LANGFUSE_OTEL_AUTH_BASIC

LANGFUSE_VERSION=3.172.1

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
SALT=
ENCRYPTION_KEY=

LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_POSTGRES_PASSWORD=
LANGFUSE_REDIS_AUTH=
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=

LANGFUSE_INIT_ORG_ID=multichain
LANGFUSE_INIT_ORG_NAME=Multichain
LANGFUSE_INIT_PROJECT_ID=agent
LANGFUSE_INIT_PROJECT_NAME=Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

# Pre-computed Basic auth header for otel-collector → Langfuse OTLP
# ingest (base64 of "$PK:$SK").
LANGFUSE_OTEL_AUTH_BASIC=
