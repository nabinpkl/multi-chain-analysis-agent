
# ─── Server ───────────────────────────────────────────────────────────
PORT=8002
CORS_ORIGIN=<http://localhost:3000>  # frontend origin for CORS headers
RUST_LOG=info,tower_http=debug
# LOG_FORMAT=json   # uncomment for prod (JSON lines for log shippers)

# ─── ClickHouse ───────────────────────────────────────────────────────
# Inside docker-compose these are overridden by the api service env block.
# These values are for running the server outside docker (cargo run).
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=multichain
CLICKHOUSE_USER=default
# Generate with: openssl rand -base64 24 | tr -d '/+=' | head -c 32
CLICKHOUSE_PASSWORD=

# ─── Solana RPC ───────────────────────────────────────────────────────
# Public mainnet caps per IP: 100 req/10s global, 40 req/10s per RPC method,
# 40 concurrent conns, 100 MB/30s. 1000ms = 1 req/s, comfortably under every
# cap (4x under per-method, ~3x under data). Drop to 400ms to keep pace with
# tip, but expect more 429s. Raise for backfill modes.
SOLANA_RPC_URL=https://api.mainnet.solana.com
RPC_MIN_INTERVAL_MS=1000
INGEST_BATCH_SIZE=10000
INGEST_FLUSH_SECS=5

# ─── Cloudflare Tunnel ────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Agent (ship-0) ───────────────────────────────────────────────────
# Provider via rig (provider-agnostic per D-2 in
# architecture-decisions/chain-analysis-agent/01-agent-overview.md).
# v0 supports `openrouter` only. Pinned model identifiers per
# environment; updating either is a deliberate code change with an
# eval-suite gate (phase 06).
AGENT_PROVIDER=openrouter
AGENT_PRIMARY_MODEL=
AGENT_POLICY_MODEL=
AGENT_API_KEY=
