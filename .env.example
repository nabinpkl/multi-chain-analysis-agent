
# ─── Server ───────────────────────────────────────────────────────────
PORT=8002
CORS_ORIGIN=<http://localhost:3000>  # frontend origin for CORS headers
RUST_LOG=info,tower_http=debug
# LOG_FORMAT=json   # uncomment for prod (JSON lines for log shippers)

# ─── ClickHouse ───────────────────────────────────────────────────────
# Inside docker-compose these are overridden by the api service env block.
# These values are for running the server outside docker (cargo run).
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=multichain
CLICKHOUSE_USER=default
# Generate with: openssl rand -base64 24 | tr -d '/+=' | head -c 32
CLICKHOUSE_PASSWORD=

# ─── Solana RPC ───────────────────────────────────────────────────────
# Public mainnet caps per IP: 100 req/10s global, 40 req/10s per RPC method,
# 40 concurrent conns, 100 MB/30s. 1000ms = 1 req/s, comfortably under every
# cap (4x under per-method, ~3x under data). Drop to 400ms to keep pace with
# tip, but expect more 429s. Raise for backfill modes.
SOLANA_RPC_URL=https://api.mainnet.solana.com
RPC_MIN_INTERVAL_MS=1000
INGEST_BATCH_SIZE=10000
INGEST_FLUSH_SECS=5

# ─── Cloudflare Tunnel ────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Agent (ship-0) ───────────────────────────────────────────────────
# Provider via rig (provider-agnostic per D-2 in
# architecture-decisions/chain-analysis-agent/01-agent-overview.md).
# v0 supports `openrouter` only. Pinned model identifiers per
# environment; updating either is a deliberate code change with an
# eval-suite gate (phase 06).
AGENT_PROVIDER=openrouter
AGENT_PRIMARY_MODEL=
AGENT_POLICY_MODEL=
AGENT_API_KEY=

# ─── Langfuse self-hosted (Ship 1 step C, ADR 13) ─────────────────────
# Self-hosted Langfuse v3 stack, fed by the otel-collector via OTLP HTTP.
# UI lands at http://localhost:3000 after first boot. The
# LANGFUSE_INIT_* envvars below auto-create org + project + user +
# API keypair on first startup; deleting `data/langfuse-postgres`
# and starting again re-bootstraps from these values. See ADR 13 for
# why we accept the v3 architecture's storage footprint
# (postgres + redis + minio + dedicated clickhouse).
#
# Generate every secret below before any non-local use. One-shot
# script (zsh):
#   for k in NEXTAUTH_SECRET SALT LANGFUSE_CLICKHOUSE_PASSWORD \
#            LANGFUSE_POSTGRES_PASSWORD LANGFUSE_REDIS_AUTH \
#            LANGFUSE_MINIO_ROOT_PASSWORD LANGFUSE_INIT_USER_PASSWORD; do
#     echo "$k=$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)"
#   done
#   echo "ENCRYPTION_KEY=$(openssl rand -hex 32)"
#   echo "LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-$(openssl rand -hex 16)"
#   echo "LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-$(openssl rand -hex 32)"
# Then build the OTel auth header:
#   printf '%s:%s' "$PK" "$SK" | base64 -> LANGFUSE_OTEL_AUTH_BASIC

LANGFUSE_VERSION=3.172.1

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
SALT=
ENCRYPTION_KEY=

LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_POSTGRES_PASSWORD=
LANGFUSE_REDIS_AUTH=
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=

LANGFUSE_INIT_ORG_ID=multichain
LANGFUSE_INIT_ORG_NAME=Multichain
LANGFUSE_INIT_PROJECT_ID=agent
LANGFUSE_INIT_PROJECT_NAME=Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

# Pre-computed Basic auth header for otel-collector → Langfuse OTLP
# ingest (base64 of "$PK:$SK").
LANGFUSE_OTEL_AUTH_BASIC=
